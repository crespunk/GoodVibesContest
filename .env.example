# Database
# If using Neon, DATABASE_URL should be the pooled (PgBouncer, "-pooler") connection
# string, and DIRECT_URL the unpooled one — Prisma migrations need a direct connection,
# but the app's runtime queries should go through the pooler so it can transparently
# reconnect if Neon suspends/restarts the underlying compute (see "terminating connection
# due to administrator command" in README's Troubleshooting section).
DATABASE_URL="postgresql://user:password@localhost:5432/nexus_protocol"
DIRECT_URL="postgresql://user:password@localhost:5432/nexus_protocol"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# Groq AI (NPC dialogue, hints, narrative generation)
GROQ_API_KEY="gsk_..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Rate Limiting
AI_RATE_LIMIT_REQUESTS=10
AI_RATE_LIMIT_WINDOW_MS=60000
